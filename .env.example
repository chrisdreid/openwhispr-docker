# Which model to load at server startup.
# See README — `tiny`, `base`, `small`, `medium`, `turbo`, `large-v3`,
# `distil-large-v3`, `parakeet`, `parakeet-v3`.
MODEL=turbo

# `cuda` or `cpu`.
DEVICE=cuda

# Whisper compute type:
#   Pascal (GTX 10xx, e.g. 1080)        → int8
#   Turing (RTX 20xx)                   → float16  or int8_float16
#   Ampere+ (RTX 30xx / 40xx)           → float16
#   CPU                                 → int8
COMPUTE_TYPE=int8

# Where models live on the host. The container expects two subdirs:
#   ${MODEL_DIR}/huggingface  → /root/.cache/huggingface
#   ${MODEL_DIR}/parakeet     → /root/.cache/local-transcribe/parakeet
# `setup.sh` creates these (as symlinks to your existing host caches if found).
MODEL_DIR=./models

# Bind address and port on the host. Use 0.0.0.0 to expose on the LAN.
BIND_HOST=127.0.0.1
PORT=8080
